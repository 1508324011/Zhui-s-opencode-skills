{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",

  // Global DCP template for the superpowers / OMO line.
  // Keep this aligned with the current official DCP schema.
  "enabled": true,

  // Keep daily use quiet, but leave DCP active.
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",

  // Keep slash commands available.
  "commands": {
    "enabled": true,
    "protectedTools": []
  },

  // Let automatic strategies run without requiring manual mode.
  "manualMode": {
    "enabled": false,
    "automaticStrategies": true
  },

  // Preserve a few recent turns before pruning tool-heavy sessions.
  "turnProtection": {
    "enabled": true,
    "turns": 4
  },

  // Protect common project metadata and test files from file-path based pruning.
  "protectedFilePatterns": [
    "**/*.test.*",
    "**/*.spec.*",
    "**/package.json",
    "**/requirements.txt",
    "**/Cargo.toml"
  ],

  // Stay conservative and close to documented defaults for the unified compress tool.
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "maxContextLimit": 100000,
    "minContextLimit": 50000,
    "nudgeFrequency": 5,
    "iterationNudgeThreshold": 15,
    "nudgeForce": "soft",
    "protectUserMessages": false
  },

  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": []
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": []
    }
  }
}
