// OpenCode Memory 配置模板
// 复制到 ~/.config/opencode/opencode-mem.jsonc 后，再在本地填写真实 memoryApiKey。
// 不要把填写过真实密钥的 opencode-mem.jsonc 提交到 Git。

{
  "storagePath": "~/.opencode-mem/data",
  "embeddingModel": "Xenova/nomic-embed-text-v1",
  "webServerEnabled": true,
  "webServerPort": 4747,
  "autoCaptureEnabled": true,
  "autoCaptureLanguage": "auto",
  "memoryProvider": "openai-chat",
  "memoryModel": "qwen3.5-plus",
  "memoryApiUrl": "https://coding.dashscope.aliyuncs.com/apps/anthropic/v1",
  "memoryApiKey": "YOUR_MEMORY_API_KEY_HERE",
  "memoryTemperature": 0.3,
  "showAutoCaptureToasts": false,
  "showUserProfileToasts": false,
  "showErrorToasts": true,
  "userProfileAnalysisInterval": 10,
  "maxMemories": 50,
  "compaction": {
    "enabled": true,
    "memoryLimit": 50
  },
  "chatMessage": {
    "enabled": true,
    "maxMemories": 5,
    "excludeCurrentSession": true,
    "injectOn": "first"
  }
}
