// Oh My OpenCode 模型分配配置
// 此文件不含敏感信息，可以直接提交到版本控制
// 
// 模型说明：
// - zhui/gpt-5.3-codex: 深度推理 / 架构设计 / 规划
// - zhui/gpt-5.4: 平衡型主力模型（检索、视觉、收尾）
// - zhui/gpt-5.5: 主力执行 / 检查 / 调试
//
// 分配策略：
// - 深度推理/架构设计 → zhui/gpt-5.3-codex
// - 代码实现/检查/调试 → zhui/gpt-5.5
// - 日常任务/外部检索/多模态 → zhui/gpt-5.4
// - 只保留 zhui provider 示例；模板里示例包含 baseURL、apiKey 占位和 setCacheKey，不包含真实 key
//
// Trellis 子代理模型说明：
// - categories.trellis-* 仅作为本地参考预设，便于让 OMO 分类命名与 Trellis 阶段保持一致
// - vendored Trellis runtime 文件保留各自显式模型默认值；本仓库不再自动把这些分类回写到 Trellis Markdown/runtime
// - 若后续 Trellis 上游有更新，先直接复核 runtime 文件，再决定是否调整本地模型默认值

{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "zhui/gpt-5.3-codex"
    },
    "hephaestus": {
      "model": "zhui/gpt-5.5"
    },
    "oracle": {
      "model": "zhui/gpt-5.5"
    },
    "librarian": {
      "model": "zhui/gpt-5.3-codex"
    },
    "explore": {
      "model": "zhui/gpt-5.3-codex"
    },
    "multimodal-looker": {
      "model": "zhui/gpt-5.4"
    },
    "prometheus": {
      "model": "zhui/gpt-5.4"
    },
    "metis": {
      "model": "zhui/gpt-5.3-codex"
    },
    "momus": {
      "model": "zhui/gpt-5.3-codex"
    },
    "atlas": {
      "model": "zhui/gpt-5.3-codex"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "zhui/gpt-5.4"
    },
    "ultrabrain": {
      "model": "zhui/gpt-5.4"
    },
    "deep": {
      "model": "zhui/gpt-5.5"
    },
    "artistry": {
      "model": "zhui/gpt-5.3-codex"
    },
    "quick": {
      "model": "zhui/gpt-5.3-codex"
    },
    "unspecified-low": {
      "model": "zhui/gpt-5.3-codex"
    },
    "unspecified-high": {
      "model": "zhui/gpt-5.4"
    },
    "writing": {
      "model": "zhui/gpt-5.3-codex"
    },
    "trellis-research": {
      "model": "zhui/gpt-5.4"
    },
    "trellis-implement": {
      "model": "zhui/gpt-5.5"
    },
    "trellis-check": {
      "model": "zhui/gpt-5.5"
    },
    "trellis-debug": {
      "model": "zhui/gpt-5.5"
    },
    "trellis-finish": {
      "model": "zhui/gpt-5.4"
    }
  }
}
